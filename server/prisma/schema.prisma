generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Rol {
  DIRECTOR
  APOYO_DIRECTOR
  RESIDENTE
  ALMACENISTA
  CONTABILIDAD
}

enum EstadoProyecto {
  PLANIFICADO
  EN_EJECUCION
  FINALIZADO
  SUSPENDIDO
}

enum EstadoDelegacion {
  ACTIVA
  COMPLETADA
  REVOCADA
}

enum Segmento {
  MATERIALES
  EQUIPOS
  HERRAMIENTAS
  SERVICIOS
}

enum OrigenProveedor {
  LOCAL
  WEB_SEARCH
}

enum CanalRequisicion {
  APP
  WHATSAPP
  GMAIL
}

enum EstadoRequisicion {
  BORRADOR
  PENDIENTE_JUST
  ENVIADA
  APROBADA
  RECHAZADA
  EN_COTIZACION
  OC_EMITIDA
  CERRADA
  EXPIRADA
}

enum Prioridad {
  ALTA
  MEDIA
  BAJA
}

enum EstadoCotizacion {
  EN_BUSQUEDA
  PENDIENTE_APROBACION
  APROBADA
  RECHAZADA
}

enum FuentePrecio {
  HISTORIAL
  LOCAL
  WEB
}

enum Confiabilidad {
  VALIDADO
  LOCAL
  REFERENCIA
}

enum EstadoOrden {
  EMITIDA
  ENVIADA
  ENTREGADA
  PAGADA
  COMPLETADA
  CANCELADA
}

// ─── Modelos ──────────────────────────────────────────────────────────────────

model Company {
  id                 String   @id @default(cuid())
  razonSocial        String
  nit                String   @unique
  representanteLegal String?
  emailCorporativo   String?
  telefono           String?
  direccion          String?
  ciudad             String?
  banco              String?
  tipoCuenta         String?
  numeroCuenta       String?
  logoUrl            String?  @db.Text
  firmaUrl           String?  @db.Text
  // Configuración tributaria (DIAN) por defecto de la empresa
  ivaPorcentaje        Decimal @default(19) @db.Decimal(5, 2)
  retefuentePorcentaje Decimal @default(0)  @db.Decimal(5, 2)
  reteIcaPorMil        Decimal @default(0)  @db.Decimal(6, 3)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]
  projects      Project[]
  suppliers     Supplier[]
  priceHistory  PriceHistory[]
  auditLogs     AuditLog[]
  delegations   Delegation[]
  basicPrices   BasicPrice[]
  notifications Notification[]
}

model User {
  id             String   @id @default(cuid())
  companyId      String
  nombre         String
  email          String   @unique
  passwordHash   String
  whatsapp       String?
  rol            Rol
  topeAprobacion Decimal  @default(0) @db.Decimal(15, 2)
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company                Company        @relation(fields: [companyId], references: [id])
  requisicionesCreadas   Requisition[]  @relation("solicitante")
  requisicionesAprobadas Requisition[]  @relation("aprobador")
  auditLogs              AuditLog[]
  priceHistory           PriceHistory[]
  delegacionesDadas      Delegation[]   @relation("delegante")
  delegacionesRecibidas  Delegation[]   @relation("delegado")
  notifications          Notification[]
}

model Project {
  id          String         @id @default(cuid())
  companyId   String
  nombre      String
  contratoNo  String
  entidad     String?
  interventor String?
  ciudad      String?
  descripcion String?
  valor       Decimal?       @db.Decimal(18, 2)
  inicio      DateTime?
  fin         DateTime?
  icono       String?        @default("🏗️")
  color       String?        @default("#1B6FF5")
  estado      EstadoProyecto @default(PLANIFICADO)
  activo      Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company      Company        @relation(fields: [companyId], references: [id])
  itemsAPU     ItemAPU[]
  requisitions Requisition[]
  budgetSheets BudgetSheet[]
  delegations  Delegation[]
  suppliers    Supplier[]
}

model BudgetSheet {
  id        String   @id @default(cuid())
  projectId String
  nombre    String
  orden     Int      @default(0)
  headers   Json
  filas     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, nombre])
}

model Delegation {
  id              String           @id @default(cuid())
  companyId       String
  projectId       String
  deleganteId     String
  delegadoId      String
  tarea           String
  descripcion     String?
  estado          EstadoDelegacion @default(ACTIVA)
  fechaLimite     DateTime?
  fechaComplecion DateTime?
  notas           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  company   Company @relation(fields: [companyId], references: [id])
  project   Project @relation(fields: [projectId], references: [id])
  delegante User    @relation("delegante", fields: [deleganteId], references: [id])
  delegado  User    @relation("delegado", fields: [delegadoId], references: [id])
}

model ItemAPU {
  id             String   @id @default(cuid())
  projectId      String
  codigo         String
  descripcion    String
  unidad         String
  cantidad       Decimal  @db.Decimal(15, 4)
  precioUnitario Decimal  @db.Decimal(15, 2)
  saldoCantidad  Decimal  @db.Decimal(15, 4)
  saldoValor     Decimal  @db.Decimal(15, 2)
  capitulo       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project          Project           @relation(fields: [projectId], references: [id])
  insumos          ItemAPUInsumo[]
  requisitionItems RequisitionItem[]
  quotationItems   QuotationItem[]
  priceHistory     PriceHistory[]

  @@unique([projectId, codigo])
}

model ItemAPUInsumo {
  id             String  @id @default(cuid())
  itemApuId      String
  tipo           String  // MATERIAL | M_DE_OBRA | EQUIPO | OTRO
  descripcion    String
  unidad         String  @default("UND")
  rendimiento    Decimal @default(0) @db.Decimal(15, 4)
  precioUnitario Decimal @default(0) @db.Decimal(15, 2)
  precioTotal    Decimal @default(0) @db.Decimal(15, 2)
  createdAt      DateTime @default(now())

  itemAPU          ItemAPU         @relation(fields: [itemApuId], references: [id], onDelete: Cascade)
  requisitionItems RequisitionItem[]
}

model Supplier {
  id         String          @id @default(cuid())
  companyId  String
  projectId  String?
  nombre     String
  nit        String?
  ciudad     String?
  segmento   Segmento
  whatsapp   String?
  email      String?
  homologado Boolean         @default(false)
  activo     Boolean         @default(true)
  rutUrl     String?
  camaraUrl  String?
  origen     OrigenProveedor @default(LOCAL)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  company          Company           @relation(fields: [companyId], references: [id])
  project          Project?          @relation(fields: [projectId], references: [id])
  quotationItems   QuotationItem[]
  quotationInvites QuotationInvite[]
  purchaseOrders   PurchaseOrder[]   @relation("proveedor")
  wonQuotations    Quotation[]       @relation("proveedorGanador")
  priceHistory     PriceHistory[]
}

model Requisition {
  id            String            @id @default(cuid())
  consecutivo   String            @unique
  projectId     String
  solicitanteId String
  aprobadorId   String?
  canal         CanalRequisicion  @default(APP)
  estado        EstadoRequisicion @default(BORRADOR)
  prioridad     Prioridad         @default(MEDIA)
  fechaLimite   DateTime?
  motivoRechazo String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  project     Project           @relation(fields: [projectId], references: [id])
  solicitante User              @relation("solicitante", fields: [solicitanteId], references: [id])
  aprobador   User?             @relation("aprobador", fields: [aprobadorId], references: [id])
  items       RequisitionItem[]
  quotation   Quotation?
}

model RequisitionItem {
  id              String  @id @default(cuid())
  requisitionId   String
  itemApuId       String?
  itemApuInsumoId String?
  descripcion     String
  cantidad        Decimal @db.Decimal(15, 4)
  unidad          String
  enAPU           Boolean @default(false)

  requisition   Requisition    @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  itemAPU       ItemAPU?       @relation(fields: [itemApuId], references: [id])
  itemAPUInsumo ItemAPUInsumo? @relation(fields: [itemApuInsumoId], references: [id], onDelete: SetNull)
}

model Quotation {
  id                 String           @id @default(cuid())
  requisitionId      String           @unique
  estado             EstadoCotizacion @default(EN_BUSQUEDA)
  proveedorGanadorId String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  requisition      Requisition       @relation(fields: [requisitionId], references: [id])
  proveedorGanador Supplier?         @relation("proveedorGanador", fields: [proveedorGanadorId], references: [id])
  items            QuotationItem[]
  invites          QuotationInvite[]
  purchaseOrders   PurchaseOrder[]
}

model QuotationItem {
  id              String        @id @default(cuid())
  quotationId     String
  supplierId      String
  itemApuId       String?
  purchaseOrderId String?
  descripcion     String?
  precioUnitario  Decimal       @db.Decimal(15, 2)
  precioTotal     Decimal       @db.Decimal(15, 2)
  tiempoEntrega   Int           @default(0)
  fuente          FuentePrecio  @default(HISTORIAL)
  confiabilidad   Confiabilidad @default(REFERENCIA)

  quotation     Quotation      @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  itemAPU       ItemAPU?       @relation(fields: [itemApuId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
}

model QuotationInvite {
  id          String    @id @default(cuid())
  quotationId String
  supplierId  String
  enviado     Boolean   @default(false)
  respondido  Boolean   @default(false)
  sentAt      DateTime?
  respondedAt DateTime?

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  supplier  Supplier  @relation(fields: [supplierId], references: [id])

  @@unique([quotationId, supplierId])
}

model PurchaseOrder {
  id                  String      @id @default(cuid())
  consecutivo         String      @unique
  quotationId         String
  supplierId          String
  estado              EstadoOrden @default(EMITIDA)
  montoTotal          Decimal     @db.Decimal(15, 2)
  fechaEmision        DateTime    @default(now())
  fechaEntregaPactada DateTime?
  fechaEntregaReal    DateTime?
  fechaPago           DateTime?
  pdfUrl              String?     @db.Text
  alertaEnviada       Boolean     @default(false)
  // Impuestos DIAN (override por OC; si null usa la config de la empresa)
  transporte           Decimal  @default(0) @db.Decimal(15, 2)
  ivaPorcentaje        Decimal? @db.Decimal(5, 2)
  retefuentePorcentaje Decimal? @db.Decimal(5, 2)
  reteIcaPorMil        Decimal? @db.Decimal(6, 3)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  quotation        Quotation       @relation(fields: [quotationId], references: [id])
  proveedor        Supplier        @relation("proveedor", fields: [supplierId], references: [id])
  itemsAdjudicados QuotationItem[]
  priceHistory     PriceHistory[]
}

model PriceHistory {
  id              String   @id @default(cuid())
  companyId       String
  supplierId      String
  itemApuId       String
  precioUnitario  Decimal  @db.Decimal(15, 2)
  ciudad          String?
  fecha           DateTime @default(now())
  purchaseOrderId String?
  registradoPorId String?

  company       Company        @relation(fields: [companyId], references: [id])
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  itemAPU       ItemAPU        @relation(fields: [itemApuId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  registradoPor User?          @relation(fields: [registradoPorId], references: [id])
}

model BasicPrice {
  id             String    @id @default(cuid())
  companyId      String
  codigo         String
  descripcion    String
  unidad         String
  precioUnitario Decimal   @db.Decimal(15, 2)
  fuente         String?
  vigencia       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, codigo])
}

model Notification {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  tipo      String // REQUISICION_CREADA | REQUISICION_APROBADA | REQUISICION_RECHAZADA | COTIZACION_INICIADA | COTIZACION_APROBADA | OC_EMITIDA | OC_ENTREGADA | OC_PAGADA
  titulo    String
  mensaje   String?
  entidad   String? // Requisition | Quotation | PurchaseOrder
  entidadId String?
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId, leida])
}

model RolePermission {
  id        String  @id @default(cuid())
  companyId String
  rol       Rol
  modulo    String // requisitions|quotations|orders|tracking|suppliers|budget|projects|delegations|users|company|whatsapp
  ver       Boolean @default(false)
  crear     Boolean @default(false)
  editar    Boolean @default(false)
  eliminar  Boolean @default(false)

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, rol, modulo])
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  accion    String
  entidad   String
  entidadId String
  ip        String?
  canal     String?
  metadata  Json?
  timestamp DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}
