# ─── Base de datos ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://procura:procura_secret@postgres:5432/procura_dev

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_32_caracteres
JWT_EXPIRES_IN=7d

# ─── WhatsApp ────────────────────────────────────────────────────────────────
# Indicativo de país por defecto: si un número se guarda sin él, se antepone.
# Colombia = 57. Así los usuarios/proveedores pueden escribir el número con o sin el 57.
DEFAULT_COUNTRY_CODE=57

# ─── Superadmin de plataforma ────────────────────────────────────────────────
# Al arrancar el API se crea/asegura este usuario con acceso cruzado a todas las
# empresas (panel /admin). Si se omiten, no se crea ningún superadmin.
SUPERADMIN_EMAIL=tu-correo@procura.ai
SUPERADMIN_PASSWORD=cambia_esta_clave_segura

# ─── Groq API ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Anthropic Claude API ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── SendGrid (correo) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=no-reply@procura.ai
SENDGRID_FROM_NAME=PROCURA AI

# ─── Twilio (WhatsApp) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── Cloudflare R2 (archivos PDF, logos, firmas) ─────────────────────────────
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=procura-docs
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

